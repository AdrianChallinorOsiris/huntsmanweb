# Google Analytics 4 Measurement ID
# Get this from: https://analytics.google.com → Admin → Data Streams → Your stream → Measurement ID
# Format: G-XXXXXXXXXX
NUXT_PUBLIC_GTAG_ID=G-XXXXXXXXXX

# Join WhatsApp form - email delivery (Resend)
# Get API key from: https://resend.com
NUXT_RESEND_API_KEY=re_xxxxxxxxxxxx
# Email address to receive join requests
NUXT_JOIN_WHATSAPP_RECIPIENT_EMAIL=postmaster@osiris.co.uk
