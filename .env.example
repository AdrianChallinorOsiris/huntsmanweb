# Google Analytics 4 Measurement ID
# Get this from: https://analytics.google.com → Admin → Data Streams → Your stream → Measurement ID
# Format: G-XXXXXXXXXX
NUXT_PUBLIC_GTAG_ID=G-XXXXXXXXXX

# Join WhatsApp form - email delivery (Gmail SMTP)
# Gmail address for sending
NUXT_SMTP_USER=your-email@gmail.com
# Gmail App Password (not your regular password - create at https://myaccount.google.com/apppasswords)
NUXT_SMTP_PASSWORD=your-app-password
# Email address to receive join requests
NUXT_JOIN_WHATSAPP_RECIPIENT_EMAIL=julie@juliefenner.co.uk
